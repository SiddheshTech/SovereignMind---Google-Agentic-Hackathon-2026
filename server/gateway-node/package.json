    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "graphql": "^16.8.1",
    "mongoose": "^9.7.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.20",
