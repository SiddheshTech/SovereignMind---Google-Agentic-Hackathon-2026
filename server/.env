# ==============================================================================
# SovereignMind - Server Environment Configuration
# ==============================================================================

# Node.js API Gateway Settings
PORT=4000
GRPC_SERVER_ADDRESS=localhost:50051

# FastAPI Core AI Engine Settings
GRPC_PORT=50051
SECRET_KEY=SUPER_SECRET_CONSTITUTIONAL_GOVERNANCE_DNA_KEY

# Database & Cache Configurations
# (Automatic sqlite fallback is used if these are left blank or offline)
# We can use sqlite for local testing and postgres for prod. Defaulting to sqlite for now.
DATABASE_URL=sqlite+aiosqlite:///./sovereignmind.db
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sovereignmind
REDIS_URL=redis://localhost:6379/0

# Firebase Realtime Database / Firestore Integration
# (Automatic JSON mock client fallback is used if this is left blank or offline)
FIREBASE_CREDENTIALS_PATH=credentials/firebase-service-account.json

# Arize Phoenix & OpenTelemetry Instrumentation Endpoint
# (Automatic local console logs fallback is used if this is offline)
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# Multi-Agent LLM Orchestration API Keys
# (Set your actual API keys here for real-time model invocation)
GEMINI_API_KEY=AIzaSyYourGeminiKeyPlaceholder
OPENAI_API_KEY=
CLAUDE_API_KEY=
GROQ_API_KEY=gsk_YourGroqKeyPlaceholder
MISTRAL_API_KEY=YourMistralKeyPlaceholder
